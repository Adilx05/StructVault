<mah:MetroWindow x:Class="StructVault.Desktop.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
                 xmlns:viewModels="clr-namespace:StructVault.Desktop.ViewModels"
                 Title="StructVault"
                 TitleCharacterCasing="Normal"
                 WindowStartupLocation="CenterScreen"
                 Height="720"
                 Width="1100"
                 MinHeight="520"
                 MinWidth="860">
    <mah:MetroWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <HierarchicalDataTemplate DataType="{x:Type viewModels:VaultTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=TreeView}}"
                       Text="{Binding Name}">
                <TextBlock.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding PlacementTarget.Tag.AddChildNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"
                                  Header="Add child node" />
                        <MenuItem Command="{Binding PlacementTarget.Tag.RenameNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"
                                  Header="Rename node" />
                        <MenuItem Command="{Binding PlacementTarget.Tag.AddFieldCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"
                                  Header="Add field" />
                        <Separator />
                        <MenuItem Command="{Binding PlacementTarget.Tag.DeleteNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"
                                  Header="Delete node" />
                    </ContextMenu>
                </TextBlock.ContextMenu>
            </TextBlock>
        </HierarchicalDataTemplate>
        <DataTemplate DataType="{x:Type viewModels:VaultFieldViewModel}">
            <Border Margin="0,0,0,10"
                    Padding="12"
                    Background="White"
                    BorderBrush="#FFE1E1E1"
                    BorderThickness="1"
                    CornerRadius="4"
                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                <Border.ContextMenu>
                    <ContextMenu>
                        <MenuItem Command="{Binding PlacementTarget.Tag.EditFieldCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"
                                  Header="Edit field" />
                        <MenuItem Command="{Binding PlacementTarget.Tag.DeleteFieldCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                  CommandParameter="{Binding}"
                                  Header="Delete field" />
                    </ContextMenu>
                </Border.ContextMenu>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               FontWeight="SemiBold"
                               Text="{Binding Key}"
                               TextWrapping="Wrap" />
                    <TextBox Grid.Row="1"
                             Margin="0,6,0,0"
                             IsReadOnly="True"
                             Text="{Binding DisplayValue}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Border>
        </DataTemplate>
    </mah:MetroWindow.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0"
                   Margin="0,0,0,12"
                   LastChildFill="True">
            <TextBlock DockPanel.Dock="Left"
                       VerticalAlignment="Center"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Text="StructVault" />
            <TextBlock Margin="16,6,0,0"
                       VerticalAlignment="Center"
                       Foreground="#FF666666"
                       Text="Offline structured vault"
                       TextWrapping="NoWrap" />
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"
                                  MinWidth="240" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*"
                                  MinWidth="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="12"
                    Background="#FFF8F8F8"
                    BorderBrush="#FFD6D6D6"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Margin="0,0,0,8"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Text="Vault structure" />

                    <TreeView x:Name="VaultTreeView"
                              Grid.Row="1"
                              ItemsSource="{Binding VaultNodes}"
                              BorderThickness="0"
                              SelectedItemChanged="VaultTreeView_SelectedItemChanged"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              Tag="{Binding}">
                        <TreeView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding PlacementTarget.Tag.AddRootNodeCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                          Header="Add root node" />
                            </ContextMenu>
                        </TreeView.ContextMenu>
                    </TreeView>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="8"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border Grid.Column="2"
                    Padding="16"
                    Background="#FFF8F8F8"
                    BorderBrush="#FFD6D6D6"
                    BorderThickness="1"
                    CornerRadius="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0"
                               Margin="0,0,0,12"
                               LastChildFill="True">
                        <TextBlock DockPanel.Dock="Left"
                                   VerticalAlignment="Center"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Text="Details" />
                        <TextBlock Margin="12,4,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#FF666666"
                                   Text="Select a vault node to view its fields."
                                   TextWrapping="Wrap" />
                    </DockPanel>

                    <ScrollViewer x:Name="VaultDetailScrollViewer"
                                  Grid.Row="1"
                                  HorizontalScrollBarVisibility="Disabled"
                                  VerticalScrollBarVisibility="Auto">
                        <Border MinHeight="240"
                                Padding="24"
                                BorderBrush="#FFE6E6E6"
                                BorderThickness="1"
                                CornerRadius="4">
                            <Grid>
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSelectedNode}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock HorizontalAlignment="Center"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Text="No node selected" />
                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Center"
                                               Foreground="#FF666666"
                                               Text="Choose an item from the vault structure to inspect its details."
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <StackPanel Visibility="{Binding HasSelectedNode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock FontSize="20"
                                               FontWeight="SemiBold"
                                               Text="{Binding SelectedNodeName}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,16"
                                               Foreground="#FF666666"
                                               Text="Fields" />
                                    <TextBlock Margin="0,0,0,12"
                                               Foreground="#FF666666"
                                               Text="This node does not contain any fields."
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasSelectedFields}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <ItemsControl ItemsSource="{Binding SelectedFields}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</mah:MetroWindow>
